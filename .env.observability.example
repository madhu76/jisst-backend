# ── Observability (add these to your Vercel project env as well) ──────────────

# GlitchTip DSN for the BACKEND project (Settings -> Projects -> <backend> -> DSN)
SENTRY_DSN=

# HomeServer ingest gateway base URL (no trailing slash)
INGEST_URL=https://homejisst-ingest.mavsankar.com

# Must match INGEST_TOKEN in HomeServer/observability/.env
INGEST_TOKEN=

# Optional tuning
LOG_LEVEL=info
INGEST_TIMEOUT_MS=1500
